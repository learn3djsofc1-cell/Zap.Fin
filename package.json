    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express-session": "^1.18.2",
    "@types/pg": "^8.18.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
